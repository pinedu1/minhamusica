{
  "name": "minhamusica",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "testes": "npm run test:domain && npm run test:persistence && npm run test:abcjs && npm run test:integration",
    "test:domain": "vitest run src/tests/domain",
    "test:adapters": "vitest run src/tests/adapters",
    "test:persistence": "vitest run src/tests/adapters/persistence",
    "test:abcjs": "vitest run src/tests/adapters/abcjs",
    "test:integration": "vitest run src/tests/integration",
    "lint": "eslint src --ext .js,.ts",
    "sass": "sass src/style/style.scss:src/style/style.css",
    "sass:watch": "sass --watch src/style/style.scss:src/style/style.css"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "eslint": "^10.2.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-stylistic": "^0.0.0-0",
    "globals": "^17.5.0",
    "sass": "^1.98.0",
    "vite": "^8.0.7",
    "vitest": "^4.1.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "dependencies": {
    "abcjs": "^6.6.2",
    "html2pdf.js": "^0.14.0",
    "zod": "^4.3.6"
  }
}
