{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
        "@adapters/*": ["src/adapters/*"]
      , "@abcjs/*": ["src/adapters/abcjs/*"]
      , "@persistence/*": ["src/adapters/persistence/*"]
      , "@domain/*": ["src/domain/*"]
      , "@schemas/*": ["src/schemas/*"]
      , "@services/*": ["src/services/*"]
      , "@styles/*": ["src/styles/*"]
      , "@data/*": ["src/data/*"]
      , "@tests/*": ["src/tests/*"]
      , "@transposer/*": ["src/transposer/*"]
    }
  },
  "exclude": ["node_modules", "dist", "_legacy"]
}
