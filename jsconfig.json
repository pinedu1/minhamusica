{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@model/*": ["src/model/*"],
      "@schemas/*": ["src/schemas/*"],
      "@services/*": ["src/services/*"],
      "@styles/*": ["src/styles/*"],
      "@data/*": ["src/data/*"],
      "@tests/*": ["src/tests/*"],
      "@transposer/*": ["src/transposer/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
